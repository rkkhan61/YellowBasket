rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Each user can only read and write their own document.
    // This covers the top-level user profile including the embedded
    // ingredients array stored at users/{userId}.ingredients
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;

      // Subcollection placeholder — if ingredients are ever moved to a
      // subcollection (users/{userId}/ingredients/{ingredientId}),
      // the same ownership rule applies.
      match /ingredients/{ingredientId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // Deny everything else by default.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
